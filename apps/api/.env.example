NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_APP_URL=http://localhost:5173

# Supabase Dashboard > Connect
# Use the shared session pooler for this long-running API and Prisma migrations.
DATABASE_URL="postgresql://prisma.PROJECT_REF:YOUR_PRISMA_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=30&pool_timeout=60&connection_limit=1"

# Supabase Dashboard > Project Settings > API Keys
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=PASTE_YOUR_SUPABASE_PUBLISHABLE_KEY_HERE
SUPABASE_SECRET_KEY=PASTE_YOUR_SUPABASE_SECRET_KEY_HERE

JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
TOKEN_ENCRYPTION_KEY_VERSION=1
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
ACCESS_SESSION_TTL_MINUTES=15
REFRESH_SESSION_TTL_DAYS=14
OAUTH_STATE_TTL_MINUTES=10
AUTH_RATE_LIMIT_WINDOW_MINUTES=10
AUTH_RATE_LIMIT_MAX_REQUESTS=30
LOG_LEVEL=debug
TRUST_PROXY_HOPS=0
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_LOGIN_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"
GOOGLE_GMAIL_REDIRECT_URI="http://localhost:4000/api/integrations/google/callback"
OPENAI_API_KEY=replace-with-llm-key
LLM_MODEL=gpt-5.4-mini
