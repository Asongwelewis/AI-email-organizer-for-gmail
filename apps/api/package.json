{
  "name": "@mailmind/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "test": "vitest run",
    "test:database": "vitest run database.integration.test.ts",
    "audit:database": "tsx test/database.audit.ts"
  },
  "dependencies": {
    "@mailmind/shared": "0.1.0",
    "@prisma/client": "^6.11.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.2.1",
    "googleapis": "^157.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^9.8.0",
    "pino-pretty": "^13.1.1",
    "tldts": "7.4.9",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.1",
    "prisma": "^6.11.1",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.20.3",
    "vitest": "^4.1.10"
  }
}
