{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "@web/*": ["src/*"],
      "@mailmind/shared": ["../../packages/shared/src/index.ts"],
      "@mailmind/shared/*": ["../../packages/shared/src/*"],
      "@mailmind/ui": ["../../packages/ui/src/index.ts"],
      "@mailmind/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules"],
  "references": [{ "path": "../../packages/shared" }, { "path": "../../packages/ui" }]
}
